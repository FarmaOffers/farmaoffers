<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template reutilizable de productos -->
    <record id="homepage_products_item" model="ir.ui.view">
        <field name="name">Farmaoffers Product Item</field>
        <field name="type">qweb</field>
        <field name="key">theme_farmaoffers.homepage_products_item</field>
        <field name="arch" type="xml">
            <t t-name="homepage_products_item">
                <t t-set="combination_info" t-value="product._get_combination_info()" />
                <form action="/shop/cart/update" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
                    <div itemscope="itemscope" itemtype="http://schema.org/Product" class="product_cards card border-0 shadow-sm h-100 my-3">
                        <!-- Imagen del producto -->
                        <div class="oe_product_image">
                            <a itemprop="url" t-att-href="'/shop/product/%s' % slug(product)">
                                <img class="card-img-top img-fluid"
                                     itemprop="image"
                                     t-att-src="'/web/image/product.template/%s/image_512' % product.id"
                                     t-att-alt="product.name" />
                            </a>
                        </div>
                        <!-- Botones -->
                        <div class="hover-button d-flex justify-content-center gap-2 my-2">
                            <input name="product_id" t-att-value="product.product_variant_id.id" type="hidden" />
                            <t t-if="len(product.product_variant_ids) == 1">
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="fa fa-shopping-cart"></i>
                                </button>
                            </t>
                            <t t-if="len(product.product_variant_ids) &gt; 1">
                                <a class="btn btn-sm btn-primary" t-att-href="'/shop/product/%s' % slug(product)">
                                    <i class="fa fa-shopping-cart"></i>
                                </a>
                            </t>
                            <a t-att-href="'/shop/product/%s' % slug(product)"
                               class="btn btn-sm btn-outline-secondary" title="Ver producto">
                                <i class="fa fa-eye"></i>
                            </a>
                        </div>
                        <!-- Detalles -->
                        <div class="card-body text-center">
                            <h6 class="card-title mb-2">
                                <a itemprop="name"
                                   t-att-href="'/shop/product/%s' % slug(product)"
                                   class="text-decoration-none text-dark product-name-truncate"
                                   t-field="product.name" />
                            </h6>
                            <div class="product_price">
                                <span class="fw-bold">
                                    <del t-attf-class="text-muted me-2 {{'' if combination_info['has_discounted_price'] else 'd-none'}}"
                                         t-esc="combination_info['list_price']"
                                         t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                                    <span t-if="combination_info['price']"
                                          class="text-success"
                                          t-esc="combination_info['price']"
                                          t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                                    <span itemprop="price" class="d-none" t-esc="combination_info['price']" />
                                    <span itemprop="priceCurrency" class="d-none" t-esc="website.currency_id.name" />
                                </span>
                            </div>
                        </div>
                    </div>
                </form>
            </t>
        </field>
    </record>

    <!-- Página principal -->
    <record id="farmaoffers_homepage_view" model="ir.ui.view">
        <field name="name">Farmaoffers Home Override</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="theme_grocery.grocery_homepage_view"/>
        <field name="arch" type="xml">
            <!-- Reemplaza el contenido principal -->
            <xpath expr="//div[@id='wrap']" position="replace">
                <div id="wrap" class="oe_structure">
                    <t t-set="direction" t-value="request.env['res.lang'].search([('code', '=', lang)]).direction"/>

                    <!-- Carrusel principal -->
                    <section class="pt16">
                        <div class="container">
                            <div id="homepageCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000" data-bs-wrap="true">
                                <div class="carousel-inner">
                                    <t t-foreach="website.get_homepage_sliders()" t-as="slider">
                                        <div t-attf-class="carousel-item #{'active' if loop.index0 == 0 else ''}">
                                            <a t-att-href="slider.link or '#'" t-att-title="slider.name">
                                                <img class="d-block w-100 img-fluid"
                                                     t-att-src="'/website/image/homepage.slider/%s/image' % slider.id"
                                                     t-att-alt="slider.name" />
                                            </a>
                                        </div>
                                    </t>
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#homepageCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Anterior</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#homepageCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Siguiente</span>
                                </button>
                            </div>
                        </div>
                    </section>

                    <!-- Secciones personalizadas -->
                    <section class="mt16 mb16">
                        <div class="container">
                            <t t-call="farmaoffers_design.s_top_offers" />
                        </div>
                    </section>

                    <section class="mt16 mb16">
                        <div class="container">
                            <t t-call="farmaoffers_design.t_top_products"/>
                        </div>
                    </section>

                    <section class="mt16 mb16">
                        <div class="container">
                            <t t-call="farmaoffers_design.s_our_tips" />
                        </div>
                    </section>

                    <section class="mt16 mb16">
                        <div class="container">
                            <t t-call="farmaoffers_design.s_reviews" />
                        </div>
                    </section>

                    <section class="mt16 mb32">
                        <div class="container">
                            <t t-call="farmaoffers_design.section_faqs">
                                <t t-set="title_p1" t-value="'Tips'"/>
                                <t t-set="title_p2" t-value="'Frecuentes'"/>
                                <t t-set="faqs" t-value="request.env['fo.frequent.tips'].search([('active', '=', True)])"/>
                            </t>
                        </div>
                    </section>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Página publicada -->
    <record id="farmaoffers_homepage" model="website.page">
        <field name="name">Farmaoffers Home</field>
        <field name="website_published">True</field>
        <field name="url">/farmaoffers_homepage</field>
        <field name="is_homepage" eval="True"/>
        <field name="view_id" ref="farmaoffers_homepage_view"/>
    </record>

    <!-- Establecer homepage -->
    <record id="website.default_website" model="website">
        <field name="homepage_url">/farmaoffers_homepage</field>
    </record>
</odoo>