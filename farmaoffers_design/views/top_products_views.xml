<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- LIST VIEW -->
    <record id="view_top_product_list" model="ir.ui.view">
        <field name="name">fo.top.product.list</field>
        <field name="model">fo.top.product</field>
        <field name="arch" type="xml">
            <list string="Top Products">
                <field name="sequence"/>
                <field name="product_tmpl_id"/>
                <field name="product_price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_top_product_form" model="ir.ui.view">
        <field name="name">fo.top.product.form</field>
        <field name="model">fo.top.product</field>
        <field name="arch" type="xml">
            <form string="Top Product">
                <sheet>
                    <group>
                        <field name="product_tmpl_id"
                               options="{'no_create_edit': True}"/>

                        <group>
                            <field name="product_price" readonly="1"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>

                        <group>
                            <field name="product_image_1920" widget="image" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_top_product" model="ir.actions.act_window">
        <field name="name">Top Products</field>
        <field name="res_model">fo.top.product</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
