<odoo>
    <template id="total_f2_snippet">
        <section class="total_f2" data-snippet="total_f2" data-name="Total del Pedido">
            <div class="table-responsive">
                <table class="table w-100">
                    <tbody>
                        <!-- Resolver la orden sin usar locals() -->
                        <t t-set="sale_order" t-value="request.website.sale_get_order() if hasattr(request, 'website') else (order if 'order' in qcontext else (website_sale_order if 'website_sale_order' in qcontext else None))"/>

                        <t t-if="sale_order">
                            <tr id="order_total" class="border-top">
                                <td class="text-left border-0 font-montserrat text-uppercase text-secondary font-weight-bold font-8-5">
                                    Total
                                </td>
                                <td class="text-xl-right border-0">
                                    <strong t-field="sale_order.amount_total"
                                        class="monetary_field text-black font-montserrat font-8-5 font-weight-bold"
                                        t-options='{"widget": "monetary", "display_currency": sale_order.pricelist_id.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                        <t t-else="">
                            <tr>
                                <td colspan="2" class="text-muted">
                                    <em>Sin pedido activo</em>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </section>
    </template>
</odoo>