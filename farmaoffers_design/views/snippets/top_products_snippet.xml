<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <template id="top_products_snippet" name="Top Products Snippet">
    <t t-if="not editable">
      <t t-set="top_products" t-value="request.env['website'].get_top_products()"/>
    </t>

    <section class="top_products mb-4 pt-2">
      <section class="list-slider">
        <h3 class="text-uppercase font-montserrat font-size-cards mb-0 font-weight-bold">
          <span class="text-secondary">Productos</span>
          <span class="text-primary">Top</span>
        </h3>
        <hr class="mx-0 mt-1 mb-3"/>

        <div class="owl-carousel medicine_carousel">
          <t t-if="not editable and top_products">
            <t t-call="farmaoffers_design.t_body_categories">
              <t t-set="products" t-value="top_products"/>
            </t>
          </t>
          <t t-if="editable">
            <p class="text-muted">[Vista previa del snippet Top Products]</p>
          </t>
        </div>
      </section>
    </section>
  </template>
</odoo>