<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="section_desc_disc_snippet" name="Section Description &amp; Disclaimer">
    <t t-if="not editable">
      <!-- Obtenemos variables solo si el entorno web está disponible -->
      <t t-set="product" t-value="request.env.context.get('product') if request else None"/>
      <t t-set="res_company" t-value="request.env.company if request else None"/>
    </t>

    <section class="section_desc_disc info-section-dd font-montserrat font-size-cards mb-4"
             data-snippet="section_desc_disc"
             data-name="Section Description &amp; Disclaimer">

      <t t-if="not editable and ((product and product.description) or (res_company and res_company.disclaimer))">
        <ul class="nav nav-tabs">
          <t t-if="product and product.description">
            <li class="nav-item">
              <a class="nav-link active text-uppercase font-weight-bold"
                 data-bs-toggle="tab" href="#description">Descripción</a>
            </li>
          </t>
          <t t-if="res_company and res_company.disclaimer">
            <li class="nav-item">
              <a t-att-class="'nav-link text-uppercase font-weight-bold ' + ('' if (product and product.description) else 'active')"
                 data-bs-toggle="tab" href="#disclaimer">Disclaimer</a>
            </li>
          </t>
        </ul>

        <div class="tab-content mt-2 px-3 border rounded">
          <t t-if="product and product.description">
            <div id="description" class="container tab-pane active">
              <br/>
              <p t-esc="product.description"/>
            </div>
          </t>
          <t t-if="res_company and res_company.disclaimer">
            <div id="disclaimer"
                 t-att-class="'container tab-pane ' + ('active' if not (product and product.description) else 'fade')">
              <br/>
              <p t-esc="res_company.disclaimer"/>
            </div>
          </t>
        </div>
      </t>

      <t t-if="editable">
        <div class="alert alert-secondary text-muted mt-2" role="alert">
          [Vista previa del snippet Section Description &amp; Disclaimer]
        </div>
      </t>

    </section>
  </template>
</odoo>