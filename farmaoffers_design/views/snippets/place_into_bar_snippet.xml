<odoo>
  <template id="place_into_bar_snippet" name="Place Into Bar Snippet">
    <section class="place_into_bar" data-snippet="place_into_bar" data-name="Place Into Bar">
      <div class="container-fluid py-2 bg-light border-bottom">
        <div class="d-flex justify-content-between align-items-center">
          <div class="d-flex align-items-center">
            <i class="fa fa-shopping-cart me-2 text-secondary"></i>
            <span class="fw-semibold">Resumen del carrito</span>
          </div>

          <div class="text-end">
            <!-- Manejo seguro: solo evalúa si existe el entorno de website_sale -->
            <t t-set="order"
               t-value="env['sale.order'].sudo().search([('id', '=', request.session.get('sale_order_id'))], limit=1)"/>

            <t t-if="order">
              <span class="text-muted">Total:</span>
              <span class="fw-bold">
                <t t-esc="order.amount_total"/> <t t-esc="order.currency_id.symbol"/>
              </span>
            </t>
            <t t-else="">
              <span class="text-muted small">Sin pedido activo</span>
            </t>
          </div>
        </div>
      </div>
    </section>
  </template>
</odoo>