<odoo>
  <template id="breadcrumb_fo_snippet" name="Breadcrumb FarmaOffers">
    <section class="breadcrumb_fo" data-snippet="breadcrumb_fo" data-name="Breadcrumb FarmaOffers">
      <t t-if="not editable">
        <div class="container font-montserrat text-uppercase breadcrumb-container py-2">
          <div class="d-flex flex-row align-items-center font-8-5">
            <a href="/" class="text-secondary font-weight-bold">Inicio</a>
            <span class="mx-2 text-secondary">/</span>
            <t t-if="request and request.env.context.get('breadcrumb_title')">
              <span class="text-primary" t-esc="request.env.context.get('breadcrumb_title')" />
            </t>
            <t t-else="">
              <span class="text-primary">Página actual</span>
            </t>
          </div>
        </div>
      </t>
      <t t-if="editable">
        <div class="text-center py-2 text-muted">[Vista previa del snippet Breadcrumb]</div>
      </t>
    </section>
  </template>
</odoo>