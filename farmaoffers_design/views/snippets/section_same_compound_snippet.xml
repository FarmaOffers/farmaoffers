<odoo>
  <template id="section_same_compound_snippet" name="Productos con el mismo compuesto activo">
    <section class="section_same_compound" data-snippet="section_same_compound" data-name="Productos con el mismo compuesto activo">
      <t t-if="editable">
        <div class="alert alert-info text-center">
          [Vista previa del snippet de productos con el mismo compuesto activo]
        </div>
      </t>

      <t t-if="not editable">
        <t t-set="product" t-value="request.env.context.get('product') if request else None"/>
        <t t-if="product and product.compound_id">
          <div class="container mt-4 mb-4">
            <div class="row justify-content-center">
              <div class="col-12 text-center mb-3">
                <h3 class="text-primary font-weight-bold">Productos con el mismo compuesto</h3>
                <span id="current_product_compound" class="d-none" t-esc="product.compound_id.name"/>
                <input type="hidden" class="product_template_id" t-att-value="product.id"/>
              </div>
              <div class="col-12 text-center">
                <ul id="ul-same-compound" class="list-unstyled d-inline-block">
                  <t t-foreach="product.same_compound_product_ids[:3]" t-as="p">
                    <li class="font-montserrat font-size-cards mb-2">
                      <a t-att-href="p.website_url" t-att-content="p.name" t-esc="p.name"/>
                    </li>
                  </t>
                </ul>
                <div class="mt-3">
                  <a href="#" id="show-more-with-same-compound" class="btn btn-outline-primary btn-sm">
                    Desplegar más
                  </a>
                </div>
              </div>
            </div>
          </div>
        </t>
      </t>
    </section>
  </template>
</odoo>