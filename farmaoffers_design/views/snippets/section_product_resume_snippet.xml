<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="section_product_resume_snippet" name="Section Product Resume">

    <!-- === BLOQUE CONTEXTO (antes del DOM visual) === -->
    <t t-if="not editable">
      <t t-set="website_obj" t-value="request.env['website'].get_current_website()"/>
      <t t-set="product" t-value="request.env.context.get('product')"/>
      <t t-set="items_resume" t-value="website_obj.get_general_info_by_type(product.id, 'resume') if (website_obj and product) else []"/>
    </t>

    <!-- === BLOQUE VISUAL === -->
    <section class="section_product_resume mb-4 pt-5"
             data-snippet="section_product_resume"
             data-name="Section Product Resume">

      <t t-if="not editable and (items_resume or (combination_info and combination_info.get('has_discounted_price')))">
        <h3 class="text-uppercase font-montserrat font-size-cards mb-0 font-weight-bold">
          <span class="text-secondary">Resumen</span>
          <span class="text-primary">Del producto</span>
        </h3>
        <hr class="mx-0 mt-1 mb-4"/>

        <div class="content-section">
          <table class="table table-striped font-montserrat font-size-cards">
            <tbody class="font-montserrat font-8-5 font-weight-bold">
              <t t-if="combination_info and combination_info.get('has_discounted_price')">
                <tr>
                  <th scope="row">Oferta del producto</th>
                  <td class="text-right">
                    <t t-esc="website.currency_id.symbol"/>
                    <t t-esc="combination_info['price']"/>
                  </td>
                </tr>
                <tr>
                  <th scope="row">Su ahorro</th>
                  <td class="text-right">
                    <span class="text-secondary">
                      <t t-esc="combination_info['list_price'] - combination_info['price']"
                         t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                      - <t t-esc="100 - (combination_info['price'] * 100) / combination_info['list_price']"
                           t-options="{'widget': 'float', 'precision': 0}"/> % OFF
                    </span>
                  </td>
                </tr>
              </t>

              <tr t-foreach="items_resume" t-as="item">
                <th scope="row"><t t-esc="item.title"/></th>
                <td class="text-right"><t t-esc="item.description"/></td>
              </tr>
            </tbody>
          </table>
        </div>
      </t>

      <t t-if="editable">
        <div class="alert alert-info text-center">
          [Vista previa del snippet Section Product Resume — se mostrará solo en páginas de producto]
        </div>
      </t>

    </section>
  </template>
</odoo>