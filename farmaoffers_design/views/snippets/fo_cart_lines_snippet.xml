<odoo>
  <template id="fo_cart_lines_snippet" name="Cart Lines Snippet">
    <section class="fo_cart_lines" data-snippet="fo_cart_lines" data-name="Cart Lines">
      <div class="container py-4">
        <div class="row justify-content-center">
          <div class="col-lg-10 col-md-12">
            <!-- Solo ejecuta si existe request.website -->
            <t t-if="hasattr(request, 'website') and request.website and request.website.sale_get_order()">
              <t t-set="order" t-value="request.website.sale_get_order()"/>
              <div class="table-responsive">
                <table class="table table-striped align-middle">
                  <thead>
                    <tr>
                      <th>Producto</th>
                      <th class="text-center">Cantidad</th>
                      <th class="text-end">Subtotal</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-foreach="order.order_line" t-as="line">
                      <tr>
                        <td>
                          <div class="d-flex align-items-center">
                            <img t-att-src="line.product_id.image_128 and '/web/image/product.product/' + str(line.product_id.id) + '/image_128' or '/web/static/src/img/placeholder.png'" width="60" height="60" class="me-3 rounded"/>
                            <span><t t-esc="line.product_id.display_name"/></span>
                          </div>
                        </td>
                        <td class="text-center">
                          <span t-esc="line.product_uom_qty"/> × <t t-esc="line.price_unit"/> <t t-esc="order.currency_id.symbol"/>
                        </td>
                        <td class="text-end">
                          <t t-esc="line.price_subtotal"/> <t t-esc="order.currency_id.symbol"/>
                        </td>
                      </tr>
                    </t>
                  </tbody>
                  <tfoot>
                    <tr>
                      <th colspan="2" class="text-end">Total:</th>
                      <th class="text-end">
                        <t t-esc="order.amount_total"/> <t t-esc="order.currency_id.symbol"/>
                      </th>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </t>
            <t t-else="">
              <p class="text-center my-4 text-muted">Tu carrito está vacío o el snippet se está viendo fuera del website context.</p>
            </t>
          </div>
        </div>
      </div>
    </section>
  </template>
</odoo>