<odoo>
  <template id="filters_shop_list_snippet" name="Filters Shop List">
    <section class="filters_shop_list" data-snippet="filters_shop_list" data-name="Filters Shop List">
      <div class="container py-4">
        <div class="row">
          <aside class="col-md-3 product-grid-sidebar">
            <div class="fo-side-list">
              <h5 class="mb-3">Filtrar por</h5>
              <ul class="list-unstyled">
                <li><a href="#category" class="nav-link">Categoría</a></li>
                <li><a href="#price" class="nav-link">Precio</a></li>
                <li><a href="#offers" class="nav-link">Ofertas</a></li>
                <li><a href="#name" class="nav-link">Nombre</a></li>
              </ul>
            </div>
          </aside>
          <div class="col-md-9">
            <div id="category" class="filter-section mb-5">
              <h6>Categorías</h6>
              <p>Seleccione la categoría que desea explorar.</p>
            </div>
            <div id="price" class="filter-section mb-5">
              <h6>Rango de precios</h6>
              <p>Elige el rango de precios de tus productos.</p>
            </div>
            <div id="offers" class="filter-section mb-5">
              <h6>Ofertas disponibles</h6>
              <p>Productos con descuento o promoción.</p>
            </div>
            <div id="name" class="filter-section mb-5">
              <h6>Ordenar por nombre</h6>
              <p>Ver productos en orden alfabético.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </template>
</odoo>
