<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Allow zone field in website form builder -->
    <function model="ir.model.fields" name="formbuilder_whitelist">
        <value>res.partner</value>
        <value eval="['l10n_pa_delivery_zone_id']"/>
    </function>

    <!-- Extend checkout address form -->
    <template id="address_inherit" inherit_id="website_sale.address">
        <xpath expr="//form/div/div[last()-1]" position="after">
            <div t-attf-class="mb-3 col-lg-6 div_zone">
                <label class="form-label" for="l10n_pa_delivery_zone_id">Zona</label>
                <select
                    name="l10n_pa_delivery_zone_id"
                    t-attf-class="form-select #{'is-invalid' if error.get('l10n_pa_delivery_zone_id') else ''}"
                    data-init="1">
                    <option value="">Zonas...</option>
                    <t t-foreach="zones" t-as="z">
                        <option
                            t-att-value="z.id"
                            t-att-selected="z.id == ('l10n_pa_delivery_zone_id' in checkout and country and checkout['l10n_pa_delivery_zone_id'] != '' and int(checkout['l10n_pa_delivery_zone_id']))">
                            <t t-esc="z.name" />
                        </option>
                    </t>
                </select>
                <div t-if="error.get('l10n_pa_delivery_zone_id')" class="invalid-feedback">
                    <t t-esc="error.get('l10n_pa_delivery_zone_id')" />
                </div>
            </div>
        </xpath>
    </template>

    <!-- Modify VAT label for B2B checkout -->
    <template id="address_b2b" inherit_id="website_sale.address_b2b">
        <xpath expr="//label[@for='vat']" position="replace">
            <label for="vat" class="form-label">Cédula de identidad</label>
        </xpath>
    </template>
</odoo>