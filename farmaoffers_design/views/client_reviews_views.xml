<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List -->
    <record id="view_fo_client_review_list" model="ir.ui.view">
        <field name="name">fo.client.review.list</field>
        <field name="model">fo.client.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="review"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_fo_client_review_form" model="ir.ui.view">
        <field name="name">fo.client.review.form</field>
        <field name="model">fo.client.review</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title"/>
                        <field name="review"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fo_client_review" model="ir.actions.act_window">
        <field name="name">Client Reviews</field>
        <field name="res_model">fo.client.review</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
