<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List -->
    <record id="view_farmaoffers_prescription_list" model="ir.ui.view">
        <field name="name">farmaoffers.prescription.list</field>
        <field name="model">farmaoffers.prescription</field>
        <field name="arch" type="xml">
            <list>
                <field name="submission_date"/>
                <field name="name"/>
                <field name="lastname"/>
                <field name="city"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_farmaoffers_prescription_form" model="ir.ui.view">
        <field name="name">farmaoffers.prescription.form</field>
        <field name="model">farmaoffers.prescription</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Customer Info">
                        <field name="submission_date" readonly="1"/>
                        <field name="name"/>
                        <field name="lastname"/>
                        <field name="city"/>
                        <field name="address"/>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>

                    <group string="Prescription">
                        <field name="message"/>
                        <field name="file" widget="pdf_viewer"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_farmaoffers_prescriptions" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">farmaoffers.prescription</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
