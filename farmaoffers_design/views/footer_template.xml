<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="farmaoffers_footer" inherit_id="website.layout" name="FarmaOffers - Footer"
            active="False">
            <xpath expr="//div[@id='footer']" position="replace">
                <div class="container-fluid position-relative border-top-footer">
                    <div id="footer" class="container hidden-print position-relative"
                        t-if='not no_footer'>
                        <img class="position-absolute feature-1-position"
                            src="/farmaoffers_design/static/src/img/feature_1.png" alt="feature_1" />
                        <div class="row">
                            <div class="logo-footer my-4">
                                <h2>
                                    <span t-field="res_company.logo" t-options="{'widget': 'image'}"
                                        t-att-alt="'Logo of %s' % res_company.name"
                                        t-att-title="res_company.name" />
                                </h2>
                            </div>
                        </div>
                        <div
                            class="d-flex flex-column flex-md-row flex-wrap justify-content-around justify-content-lg-between font-montserrat">
                            <div>
                                <div class="block-footer">
                                    <div class="title-block-footer">Sobre nosotros</div>
                                    <div class="content-block-footer">
                                        <ul>
                                            <li>
                                                <a href="#" title="Conoce el equipo">Conoce el
                                                    equipo</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Sobre la empresa">Sobre la
                                                    empresa</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Compañia etc">Compañia etc</a>
                                            </li>
                                            <li>
                                                <a href="#" title="This is a link">Esto es un link</a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="block-footer">
                                    <div class="title-block-footer">Servicios</div>
                                    <div class="content-block-footer">
                                        <ul>
                                            <li>
                                                <a href="#" title="Farmacia">Farmacia</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Atención al usuario">Atención al
                                                    usuario</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Doctores a domicilio">Doctores a
                                                    domicilio</a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="block-footer">
                                    <div class="title-block-footer">Productos</div>
                                    <div class="content-block-footer">
                                        <ul>
                                            <li>
                                                <a href="#" title="Ofertas">Ofertas</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Nuevos lanzamientos">Nuevos
                                                    lanzamientos</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Destacados">Destacados</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Covid-19">Covid-19</a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="block-footer">
                                    <div class="title-block-footer">Contacto</div>
                                    <div class="content-block-footer">
                                        <ul>
                                            <li>
                                                <a href="#" title="Sucursales">Sucursales</a>
                                            </li>
                                            <li>
                                                <a href="#" title="Escríbanos">Escríbanos</a>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="title-block-footer">Llámanos</div>
                                    <p class="call-number">0800-635-83748</p>
                                </div>
                            </div>
                            <div>
                                <div class="block-footer social-media-footer">
                                    <div class="title-follow-us text-center text-secondary">Síguenos</div>
                                    <div class="d-flex justify-content-center">
                                        <a t-if="res_company.social_facebook" class="mx-1"
                                            t-att-href="res_company.social_facebook"
                                            title="Facebook">
                                            <img class="social-media-icons"
                                                src="/farmaoffers_design/static/src/img/facebook-helper.png"
                                                alt="Facebook" />
                                        </a>
                                        <a t-if="res_company.social_twitter" class="mx-1"
                                            t-att-href="res_company.social_twitter" title="Twitter">
                                            <img class="social-media-icons"
                                                src="/farmaoffers_design/static/src/img/twitter-helper.png"
                                                alt="Twitter" />
                                        </a>
                                        <a t-if="res_company.social_linkedin" class="mx-1"
                                            t-att-href="res_company.social_linkedin"
                                            title="LinkedIn">
                                            <img class="social-media-icons"
                                                src="/farmaoffers_design/static/src/img/linkedin-helper.png"
                                                alt="LinkedIn" />
                                        </a>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="footer_copyright mt-2">
                    <div class="container font-montserrat">
                        <div class="pull-left">
                            <span>Copyright &amp;copy; 2021. Todos los derechos reservados.</span>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                </div>
            </xpath>
        </template>
    </data>
</odoo>