<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_fo_our_tips_list" model="ir.ui.view">
        <field name="name">fo.our.tips.list</field>
        <field name="model">fo.our.tips</field>
        <field name="arch" type="xml">
            <list>
                <field name="text"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_fo_our_tips_form" model="ir.ui.view">
        <field name="name">fo.our.tips.form</field>
        <field name="model">fo.our.tips</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="text"/>
                        <field name="image" widget="image"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fo_our_tips" model="ir.actions.act_window">
        <field name="name">Our Tips</field>
        <field name="res_model">fo.our.tips</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
