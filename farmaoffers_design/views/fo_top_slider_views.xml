<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List -->
    <record id="view_fo_top_slider_list" model="ir.ui.view">
        <field name="name">fo.top.slider.list</field>
        <field name="model">fo.top.slider</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_fo_top_slider_form" model="ir.ui.view">
        <field name="name">fo.top.slider.form</field>
        <field name="model">fo.top.slider</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="image" widget="image"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_fo_top_slider" model="ir.actions.act_window">
        <field name="name">Top Sliders</field>
        <field name="res_model">fo.top.slider</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
