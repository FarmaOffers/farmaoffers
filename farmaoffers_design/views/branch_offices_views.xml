<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List -->
    <record id="view_fo_branch_office_list" model="ir.ui.view">
        <field name="name">fo.branch.office.list</field>
        <field name="model">branch.office</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="address"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_fo_branch_office_form" model="ir.ui.view">
        <field name="name">fo.branch.office.form</field>
        <field name="model">branch.office</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="address"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fo_branch_offices" model="ir.actions.act_window">
        <field name="name">Branch Offices</field>
        <field name="res_model">branch.office</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
