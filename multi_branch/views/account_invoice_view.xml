<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- =========================================================
         Inherited Invoice Form view (account.move) - Odoo 18
         Añade branch_id en el formulario principal de la factura
         ========================================================= -->
    <record id="view_move_form_banch_inherit" model="ir.ui.view">
        <field name="name">account.move.form.branch.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Insertar branch_id después de invoice_date -->
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field
                    name="branch_id"
                    required="1"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                    modifiers="{'readonly': [('state','not in', ['draft'])]}"
                />
            </xpath>

            <!-- NOTA IMPORTANTE:
                 En Odoo 18, el one2many invoice_line_ids NO contiene <tree>/<form> inline.
                 Las columnas se definen en vistas externas de account.move.line.
                 Abajo heredo esas vistas para agregar branch_id sin causar xpath not found. -->
        </field>
    </record>

    <!-- =========================================================
         Inherited Invoice Lines LIST (account.move.line)
         Agrega branch_id como columna en la lista de líneas
         ========================================================= -->
    <record id="view_move_line_tree_branch_inherit" model="ir.ui.view">
        <field name="name">account.move.line.tree.branch.inherit</field>
        <field name="model">account.move.line</field>
        <!-- Vista de lista estándar de líneas; en Odoo 18 la etiqueta es <list> -->
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <!-- Inserta la columna dentro del <list> -->
            <xpath expr="//list" position="inside">
                <field
                    name="branch_id"
                    string="Branch"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                />
            </xpath>
        </field>
    </record>

    <!-- =========================================================
         Inherited Invoice Lines FORM (account.move.line)
         Agrega branch_id en el formulario de la línea
         ========================================================= -->
    <record id="view_move_line_form_branch_inherit" model="ir.ui.view">
        <field name="name">account.move.line.form.branch.inherit</field>
        <field name="model">account.move.line</field>
        <!-- Vista formulario estándar de línea -->
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <!-- Insertar branch_id en el primer group del sheet -->
            <xpath expr="//form/sheet//group[1]" position="inside">
                <field
                    name="branch_id"
                    string="Branch"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                />
            </xpath>
        </field>
    </record>

    <!-- =========================================================
         Inherited Invoice Search view (account.move)
         Añade campo y group_by sin depender de filtros renombrados
         ========================================================= -->
    <record id="view_account_invoice_filter_branch_inherit" model="ir.ui.view">
        <field name="name">account.move.select.branch.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <!-- Inserción robusta directamente dentro de <search> -->
            <xpath expr="//search" position="inside">
                <field name="branch_id"/>
                <filter name="group_by_branch" string="Branch" context="{'group_by':'branch_id'}"/>
            </xpath>
        </field>
    </record>

