<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Stock Location list (Odoo 18 usa <list>) -->
    <record id="view_location_tree2_inherit" model="ir.ui.view">
        <field name="name">stock.location.tree.branch.inherit</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_tree2"/>
        <field name="arch" type="xml">
            <!-- Inserta al final de la lista para evitar depender de company_id -->
            <xpath expr="//list" position="inside">
                <field
                    name="branch_id"
                    required="1"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                />
            </xpath>
        </field>
    </record>

    <!-- Stock Location form -->
    <record id="view_location_form_branch_inherit" model="ir.ui.view">
        <field name="name">stock.location.form.branch.inherit</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//field[@name='usage']" position="before">
                <field
                    name="branch_id"
                    required="1"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                />
            </xpath>
        </field>
    </record>

    <!-- Stock Move form -->
    <record id="view_move_form_branch_inherit" model="ir.ui.view">
        <field name="name">stock.move.form.branch.inherit</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//field[@name='location_id']" position="after">
                <field
                    name="branch_id"
                    options="{'no_create_edit': True}"
                    context="{'branch_filter': True, 'filter_company_id': company_id}"
                />
            </xpath>
        </field>
    </record>

    <!-- Stock Move search (añadimos campo y group_by de forma robusta) -->
    <record id="view_move_search_branch_inherit" model="ir.ui.view">
        <field name="name">stock.move.search.branch.inherit</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="branch_id"/>
                <filter name="group_by_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Stock Move pivot (anclamos al contenedor pivot, no a location_dest_id) -->
    <record id="view_move_pivot_branch_inherit" model="ir.ui.view">
        <field name="name">stock.move.pivot.branch.inherit</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//pivot" position="inside">
                <field name="branch_id" type="row"/>
            </xpath>
        </field>
    </record>
</odoo>