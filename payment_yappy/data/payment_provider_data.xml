<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="payment_provider_yappy" model="payment.provider">
            <field name="name">Yappy</field>
            <field name="code">yappy</field>
            <field name="redirect_form_view_id" ref="redirect_form"/>
            <field name="company_id" ref="base.main_company"/>
            <field name="state">disabled</field>
            <field name="image_128" type="base64" file="payment_yappy/static/src/img/yappy_icon.png"/>
            <field name="allow_tokenization">False</field>
            <field name="allow_express_checkout">False</field>
            <field name="payment_method_ids" eval="[Command.set([
                         ref('payment_method_yappy'),
                     ])]" />
        </record>

    </data>
</odoo>