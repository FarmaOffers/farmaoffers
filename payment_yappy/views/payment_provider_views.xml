<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_payment_provider_form_yappy" model="ir.ui.view">
    <field name="name">payment.provider.form.yappy</field>
    <field name="model">payment.provider</field>
    <field name="inherit_id" ref="payment.payment_provider_form"/>
    <field name="arch" type="xml">

      <group name="provider_credentials" position="inside">

        <group name="yappy_credentials" invisible="code != 'yappy'">

          <field name="yappy_merchant_id" required="code == 'yappy' and state != 'disabled'"/>

          <field name="yappy_secret_key" required="code == 'yappy' and state != 'disabled'" password="True"/>

          <field name="yappy_base_url" placeholder="https://www.midominio.com"/>

        </group>

      </group>

    </field>
  </record>

</odoo>
