<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================= SHOP PAGE ================= -->

    <template id="shop_customize" inherit_id="website_sale.products" name="Shop page FarmaOffers">

        <xpath expr="//div[@id='wrap']//div[hasclass('container')]/div[hasclass('row')][1]" position="before">
            <t t-call="farmaoffers_theme.breadcrumb_fo">
                <t t-set="bg_title" t-value="'Listado de productos'"/>
                <t t-set="breadcrumb_definition" t-value="'Productos'"/>
            </t>
            <div class="oe_structure"/>
        </xpath>

        <!-- <xpath expr="//div[hasclass('products_pager')]" position="replace"/> -->

    </template>

