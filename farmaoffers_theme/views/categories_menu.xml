<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="option_collapse_categories_recursive_header" name="Category list menu header">
        <li class="nav-item category-header my-2" style="min-width:280px;">

            <t t-set="children" t-value="c.child_id"/>

            <a t-attf-href="/shop/category/#{c.id}"
               t-attf-class="nav-link nav-link-categ d-flex justify-content-between align-items-center"
               t-att-data-haschild="'1' if children else '0'">

                <div class="d-flex flex-row gap-1">
                    <t t-if="c.image_1920">
                        <img class="fo-icon-category"
                             t-att-src="image_data_uri(c.image_1920)"/>
                    </t>

                    <span class="fo-category-name" t-field="c.name"/>
                </div>

                <i t-if="children"
                   class="text-primary fa fa-chevron-right"
                   role="img"/>

            </a>

            <ul t-if="c.child_id"
                class="border nav nav-pills flex-column flex-nowrap nav-child"
                style="background-color:white;display:none;position:absolute;top:0;left:100%;height:100%;z-index:10000;width:100%;">

                <div style="height:100%;overflow:hidden auto;width:100%;">

                    <li class="child-parent-categ mb-3 d-none">

                        <i t-if="children"
                           class="d-md-none text-primary d-inline-block p-3 fa fa-chevron-left close-item"
                           role="img"/>

                        <a t-attf-href="/shop/category/#{c.id}"
                           class="nav-link"
                           style="color:#16a2ff;">

                            Productos en <i><span t-field="c.name"/></i>

                        </a>

                    </li>

                    <t t-foreach="c.child_id" t-as="c">
                        <t t-call="farmaoffers_theme.option_collapse_categories_recursive_header"/>
                    </t>

                </div>

            </ul>

        </li>
    </template>

</odoo>