<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="farmaoffers_homepage_view" model="ir.ui.view">
      <field name="name">Farmaoffers Home</field>
      <field name="type">qweb</field>
      <field name="key">website.farmaoffers_homepage</field>
      <field name="arch" type="xml">
        <t name="Home" t-name="website.farmaoffers_homepage">
          <t t-call="website.layout">
            <t t-set="pageName" t-value="'homepage'"/>
            <t t-set="website" t-value="request.website or request.env['website'].get_current_website()"/>

            <div id="wrap" class="oe_structure">
              <section class="pt16 t_owl_carousel" data-carousel-type="homepage">
                <div class="container">
                  <div class="splide" id="slider-homepage">
                    <div class="splide__track">
                      <ul class="splide__list">
                        <t t-set="sliders" t-value="website.get_homepage_sliders()"/>
                        <t t-foreach="sliders" t-as="slider">
                          <li class="splide__slide">
                            <a t-att-href="slider.link or '#'" t-att-title="slider.name">
                              <img class="d-block w-100 img-fluid" t-att-src="'/website/image/homepage.slider/%s/image' % slider.id" t-att-alt="slider.name or ''"/>
                            </a>
                          </li>
                        </t>
                        <t t-if="not sliders">
                          <li class="splide__slide">
                            <img class="d-block w-100 img-fluid" src="/theme_grocery/static/src/img/default.jpg" alt="Default Slide"/>
                          </li>
                        </t>
                      </ul>
                    </div>
                  </div>
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

              <section class="mt16 mb16">
                <div class="container">
                  <t t-call="farmaoffers_theme.s_top_offers"/>
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

              <section class="mt16 mb16">
                <div class="container">
                  <t t-call="farmaoffers_theme.t_top_products"/>
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

              <section class="mt16 mb16">
                <div class="container">
                  <t t-call="farmaoffers_theme.s_our_tips" />
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

              <section class="mt16 mb16">
                <div class="container">
                  <t t-call="farmaoffers_theme.s_reviews"/>
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

              <section class="mt16 mb32">
                <div class="container">
                  <t t-call="farmaoffers_theme.section_faqs">
                  </t>
                </div>
              </section>

              <div class="clearfix"/>
              <div class="oe_structure"/>

            </div>
          </t>
        </t>
      </field>
    </record>

    <record id="farmaoffers_homepage" model="website.page">
      <field name="name">Farmaoffers Home</field>
      <field name="url">/farmaoffers_homepage</field>
      <field name="is_homepage" eval="True"/>
      <field name="website_published">True</field>
      <field name="view_id" ref="farmaoffers_homepage_view"/>
    </record>

    <record id="website.default_website" model="website">
      <field name="homepage_url">/farmaoffers_homepage</field>
    </record>

  </data>
</odoo>
