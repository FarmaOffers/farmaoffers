<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="products_item_inherit_customize" model="ir.ui.view">
            <field name="name">products_item_inherit_customize</field>
            <field name="inherit_id" search="[('key', '=', 'theme_grocery.products_item_inherit')]" />
            <field name="type">qweb</field>
            <field name="key">farmaoffers_theme.products_item_inherit_customize</field>
            <field name="arch" type="xml">
                <!-- Hide Quick view button -->
                <xpath expr="//form//button[hasclass('p_quick_view')]" position="replace">
                </xpath>
                <xpath expr="//form//div[hasclass('o_wsale_product_btn')]//a[hasclass('a-submit')]"
                    position="replace">
                    <a href="#" role="button" class="a-submit add-shopcart-indicator">
                        <div>
                            <span class="text-uppercase">Agregar al carrito</span>
                        </div>
                    </a>
                </xpath>
            </field>
        </record>
    </data>
</odoo>