<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <template id="checkout_pickup_toggle" inherit_id="website_sale.checkout" name="Checkout pickup toggle">
    <xpath expr="//t[@t-call='website_sale.delivery_address_row']" position="before">

      <t t-set="order" t-value="website_sale_order or website.sale_get_order()"/>
      <t t-set="shipping_mode" t-value="order.shipping_mode if order else ''"/>
      <t t-set="branch_id" t-value="order.branch_id.id if order and order.branch_id else ''"/>
      <t t-set="is_pickup" t-value="shipping_mode == 'branch'"/>

      <div id="fo_pickup_toggle" class="mb-3" 
           t-att-data-shipping-mode="shipping_mode"
           t-att-data-branch-id="branch_id">
        <h4 class="text-uppercase small fs-6 fw-bold">Entrega</h4>

        <div class="d-flex flex-wrap gap-3 mt-2">
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="fo_delivery_mode" 
                   id="fo_mode_address" value="address" 
                   t-att-checked="'checked' if not is_pickup else None"/>
            <label class="form-check-label text-uppercase fw-bold" for="fo_mode_address">
              Direccion
            </label>
          </div>

          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="fo_delivery_mode" 
                   id="fo_mode_pickup" value="pickup"
                   t-att-checked="'checked' if is_pickup else None"/>
            <label class="form-check-label text-uppercase fw-bold" for="fo_mode_pickup">
              Retiro en sucursal
            </label>
          </div>
        </div>

        <!-- Placeholder sucursal -->
        <div id="fo_pickup_branch_wrap" class="mt-3" 
             t-attf-class="#{'' if is_pickup else 'd-none'}">
          <select id="fo_branch_select" name="branch_id" class="form-select w-auto">
            <option value="">-SUCURSAL-</option>
          </select>
        </div>
      </div>

    </xpath>
  </template>

  <template id="delivery_address_row_hide_on_pickup" inherit_id="website_sale.delivery_address_row" name="Hide delivery address on pickup">
    <xpath expr="//div[@id='delivery_address_row']" position="attributes">
      <attribute name="t-attf-class" add="#{ 'd-none' if request.params.get('pickup') in ('1','true','True') else '' }" separator=" " />
    </xpath>
  </template>

  <template id="disable_delivery_form" inherit_id="website_sale.delivery_form" name="Disable delivery form (always)">
    <xpath expr="//form[@id='o_delivery_form']" position="replace"/>
  </template>

  <template id="billing_address_row_remove_same_as_delivery" inherit_id="website_sale.billing_address_row" name="Remove 'Same as delivery address' checkbox">
    <xpath expr="//div[@id='billing_address_row']/h4" position="replace"/>
    <xpath expr="//div[@id='billing_address_row']//div[contains(@class,'form-check') and contains(@class,'form-switch')]" position="replace"/>

  </template>

</odoo>
