<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="section_faqs">
        <section t-if="faqs and len(faqs) &gt; 0" class="mb-4 pt-5">

            <h3 class="text-uppercase font-montserrat font-size-cards mb-0 font-weight-bold">
                <span class="text-secondary">
                    <t t-esc="title_p1"/>
                </span>
                <span class="text-primary">
                    <t t-esc="title_p2"/>
                </span>
            </h3>

            <hr class="mx-0 mt-1 mb-4"/>

            <div class="content-section">
                <div class="accordion font-montserrat" id="faqsAccordion">

                    <t t-foreach="faqs" t-as="item" t-index="idx">
                        <div class="card">

                            <div class="card-header bg-white mb-2"
                                 t-attf-id="heading-#{item.id}">
                                <h2 class="mb-0">
                                    <button
                                        class="btn btn-block text-left text-uppercase text-primary font-montserrat font-weight-bold font-8-5"
                                        type="button"
                                        data-toggle="collapse"
                                        t-attf-data-target="#collapse-#{item.id}"
                                        aria-expanded="true"
                                        t-attf-aria-controls="collapse-#{item.id}">
                                        <t t-esc="item.title"/>
                                    </button>
                                </h2>
                            </div>

                            <div t-attf-id="collapse-#{item.id}"
                                 t-attf-class="collapse mb-2 #{ 'show' if idx == 0 else '' }"
                                 t-attf-aria-labelledby="heading-#{item.id}"
                                 data-parent="#faqsAccordion">
                                <div class="card-body font-8-5">
                                    <t t-esc="item.description"/>
                                </div>
                            </div>

                        </div>
                    </t>

                </div>
            </div>

        </section>
    </template>

</odoo>
