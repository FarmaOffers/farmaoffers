<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="farmaoffers_theme_reset_password" inherit_id="auth_signup.reset_password" name="Custom Reset Password">
      <xpath expr="." position="replace">
        <t t-call="web.login_layout">
          <div class="container-fo mx-auto my-0">
            <div class="basic-bg basic-bg-reset row">
              <div class="login-message col-12 col-md-6 d-flex justify-content-center align-items-center">
                <div class="text-white text-left font-montserrat font-weight-bold">
                  LAS MEJORES OFERTAS LAS TRAEMOS PARA USTED
                  <span class="text-green2">CADA DÍA</span>
                </div>
              </div>

              <div class="col-12 col-md-6 d-flex justify-content-center align-items-center">
                <div t-if="message" class="oe_login_form_custom clearfix flex-column login-form-custom helper-links">
                  <div class="login-img">
                    <h2>
                      <span t-field="res_company.logo" t-options="{'widget': 'image'}" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name"/>
                    </h2>
                  </div>

                  <div class="login-heading text-center">
                    <h2 class="text-dark-fo reset-h2 mb-3">¡Correo de recuperación de contraseña enviado!</h2>
                    <h3 class="m-0">Si su correo existe llegara un correo sigue las instrucciones del mensaje para restablecer su contraseña</h3>
                  </div>

                  <a class="text-center" href="/web/login" role="button">Regresar</a>
                </div>

                <form class="login-form-custom" role="form" method="post" t-if="not message">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                  <div class="login-img">
                    <h2>
                      <span t-field="res_company.logo" t-options="{'widget': 'image'}" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name"/>
                    </h2>
                  </div>

                  <t t-if="error">
                    <div class="form-group col-12 alert alert-danger font-montserrat font-8-5 mb-1" role="alert">
                      <i class="fa fa-exclamation" aria-hidden="false"></i>
                      <t t-esc="error"/>
                    </div>
                  </t>

                  <t t-if="error2">
                    <div t-foreach="error2" t-as="err" class="form-group col-12 alert alert-danger font-montserrat font-8-5 mb-1" role="alert">
                      <i class="fa fa-exclamation" aria-hidden="false"></i>
                      <t t-esc="err['error']"/>
                    </div>
                  </t>

                  <t t-if="token and not invalid_token">
                    <t t-call="auth_signup.fields">
                      <t t-set="only_passwords" t-value="1"/>
                    </t>
                  </t>

                  <t t-if="not token">
                    <div class="form-group field-login">
                      <label for="login" class="col-form-label reset-password-label text-dar-fo font-montserrat">
                        Recuperar contraseña
                      </label>
                      <input type="text" name="login" t-att-value="login" id="login" class="form-control mb-4" autofocus="autofocus" required="required" autocapitalize="off" placeholder="Ingrese su correo"/>
                    </div>
                  </t>

                  <input type="hidden" name="redirect" t-att-value="redirect"/>
                  <input type="hidden" name="token" t-att-value="token"/>

                  <div class="clearfix oe_login_buttons text-center">
                    <button type="submit" class="btn btn-secondary text-uppercase font-montserrat font-weight-bold font-8-5">
                      Recuperar
                    </button>

                    <div class="helper-links d-flex justify-content-center align-items-center small mt-2">
                      <a t-if="not token" t-attf-href="/web/login?{{ keep_query() }}">Regresar</a>
                      <a t-if="invalid_token" href="/web/login">Regresar</a>
                    </div>

                    <div class="o_login_auth"/>
                  </div>
                </form>

              </div>
            </div>
          </div>
        </t>
      </xpath>
    </template>
  </data>
</odoo>
