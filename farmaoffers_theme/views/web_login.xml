<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="farmaoffers_theme_login" inherit_id="web.login" name="Custom Login">
      <xpath expr="//form[@action='/web/login' or contains(@t-attf-action, '/web/login')]" position="replace">
        <div class="container-fo mx-auto my-0 basic-bg basic-bg-login">
          <div class="container mx-auto my-0 row">
            <div class="login-message col-12 col-md-6 d-flex justify-content-center align-items-center">
              <div class="text-white text-left font-montserrat font-weight-bold">
                LAS MEJORES OFERTAS LAS TRAEMOS PARA USTED
                <span class="text-green2">CADA DÍA</span>
              </div>
            </div>

            <div class="col-12 col-md-6 d-flex justify-content-center align-items-center">
              <form class="login-form-custom" role="form" t-attf-action="/web/login" method="post" onsubmit="this.action = '/web/login' + location.hash">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="login-img">
                  <h2>
                    <span t-field="res_company.logo" t-options="{'widget': 'image'}" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name"/>
                  </h2>
                </div>

                <div class="login-heading">
                  <h2 class="text-dark-fo m-0">Login</h2>
                  <h3 class="m-0">Ingrese su nombre y contraseña</h3>
                </div>

                <div class="form-group field-login">
                  <input type="text" placeholder="Email" name="login" t-att-value="login" id="login" t-attf-class="form-control #{'form-control-sm' if form_small else ''}" required="required" autofocus="autofocus" autocapitalize="off"/>
                </div>

                <div class="form-group field-password">
                  <input type="password" placeholder="Password" name="password" id="password" t-attf-class="form-control #{'form-control-sm' if form_small else ''}" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096"/>
                </div>

                <div class="helper-links">
                  <a href="/web/reset_password" title="¿Olvidó su contraseña?">¿Olvidó su contraseña?</a>
                  <a href="/web/signup" title="Crear cuenta">Crear cuenta</a>
                </div>

                <p class="alert alert-danger" t-if="error" role="alert">
                  <t t-esc="error"/>
                </p>
                <p class="alert alert-success" t-if="message" role="status">
                  <t t-esc="message"/>
                </p>

                <div t-attf-class="clearfix oe_login_buttons text-center mb-1 {{'pt-2' if form_small else 'pt-3'}}">
                  <button type="submit" class="btn btn-secondary text-uppercase font-montserrat font-weight-bold login-button-custom font-8-5">
                    Ingresar
                  </button>
                  <t t-if="debug">
                    <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm btn-block">
                      Log in as superuser
                    </button>
                  </t>
                  <div class="o_login_auth"/>
                </div>

                <input type="hidden" name="redirect" t-att-value="redirect"/>
              </form>
            </div>
          </div>
        </div>
      </xpath>
    </template>
  </data>
</odoo>
