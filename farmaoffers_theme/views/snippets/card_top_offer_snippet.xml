<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="card_top_offers" name="Card Top Offers">
    <div class="top_offers w-100">
      <div class="img-offer d-flex align-items-center">
        <img t-att-src="'/web/image/product.offers/%s/image' % item.id" t-att-alt="item.title or ''" style="object-fit: contain;" class="p-1"/>
      </div>
      <div class="title-offer">
        <t t-esc="item.title"/>
      </div>
    </div>
  </template>
</odoo>
