<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="accordion_snippet" name="Accordion">
    <section t-if="len(items) &gt; 0" class="mb-4 pt-5">
      <h3 class="text-uppercase font-montserrat font-size-cards mb-0 fw-bold">
        <span class="text-secondary">
          <t t-esc="title_p1" />
        </span>
        <span class="text-primary">
          <t t-esc="title_p2" />
        </span>
      </h3>
      <hr class="mx-0 mt-1 mb-4" />
      <div class="content-section">
        <div class="accordion font-montserrat" id="faqsAccordion">
          <div t-foreach="faqs" t-as="item" class="card">
            <div class="card-header bg-white mb-2" t-attf-id="heading-#{item.id}">
              <h2 class="mb-0">
                <button class="btn btn-block text-left text-uppercase text-primary font-montserrat fw-bold font-8-5" type="button" data-toggle="collapse" t-attf-data-target="#collapse-#{item.id}" aria-expanded="true" t-attf-aria-controls="collapse-#{item.id}">
                  <t t-esc="item.title" />
                </button>
              </h2>
            </div>

            <div t-attf-id="collapse-#{item.id}" t-attf-class="collapse mb-2 #{ 'show' if item_first else '' }" t-attf-aria-labelledby="heading-#{item.id}" data-parent="#faqsAccordion">
              <div class="card-body font-8-5">
                <t t-esc="item.description" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </template>
</odoo>