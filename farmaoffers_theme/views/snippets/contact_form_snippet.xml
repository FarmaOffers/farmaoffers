<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="s_contact_form" name="Contact Form">
    <section class="basic-bg basic-bg-login">
      <div class="container-fo mx-auto my-0 py-1">

        <section class="pt8 pb0" data-vcss="001" data-snippet="s_title" data-name="Title">
          <div class="container s_allow_columns font-montserrat text-uppercase">
            <h1 class="m-0" style="text-align:center;">
              <font class="text-white fw-bold font-montserrat" style="font-size: 32px;">
                Formulario de contacto
              </font>
            </h1>
          </div>
        </section>

        <section class="o_colored_level pb0 pt0" data-snippet="s_text_block" data-name="Text">
          <div class="s_allow_columns o_container_small">
            <p class="text-white font-montserrat m-0">
              Contáctenos sobre cualquier cosa relacionada con nuestra empresa o nuestros servicios.
              Haremos todo lo posible por darle respuesta a la brevedad.
            </p>

            <section>
              <div class="container">
                <form action="/contactus" method="post" class="login-form-custom p-2 p-md-3 p-lg-5">

                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                  <!-- Errores -->
                  <t t-if="error and len(error) &gt; 0">
                    <div t-foreach="error" t-as="err"
                         class="form-group col-12 alert alert-danger font-montserrat font-8-5 mb-1"
                         role="alert">
                      <i class="fa fa-exclamation" aria-hidden="false"></i>
                      <t t-esc="err['error']"/>
                    </div>
                  </t>

                  <div>
                    <div class="form-group col-12">
                      <label class="text-dark-fo mb-0" style="width: 200px" for="name">
                        <span>Nombre</span><span> *</span>
                      </label>
                      <input type="text" class="form-control" name="name" t-att-value="name" required="1" id="name"/>
                    </div>

                    <div class="form-group col-12">
                      <label class="text-dark-fo mb-0" style="width: 200px" for="lastname">
                        <span>Apellido</span>
                      </label>
                      <input type="text" class="form-control" name="lastname" t-att-value="lastname" id="lastname"/>
                    </div>

                    <div class="form-group col-12">
                      <label class="text-dark-fo mb-0" style="width: 200px" for="company">
                        <span>Compañía</span><span> *</span>
                      </label>
                      <input type="text" class="form-control" name="company" t-att-value="company" required="1" id="company"/>
                    </div>

                    <div class="form-group col-12">
                      <label class="text-dark-fo mb-0" style="width: 200px" for="email">
                        <span>Correo Electrónico</span><span> *</span>
                      </label>
                      <input type="email" class="form-control" name="email" t-att-value="email" required="1" placeholder="micorreo@email.com" id="email"/>
                    </div>

                    <div class="form-group col-12">
                      <label class="text-dark-fo mb-0" style="width: 200px" for="message">
                        <span>Mensaje</span><span> *</span>
                      </label>
                      <textarea class="form-control" name="message" required="1" id="message" rows="3"><t t-if="message" t-esc="message"/></textarea>
                    </div>

                    <div class="form-group col-12 text-right">
                      <div style="width: 200px;" class="s_website_form_label"/>
                      <button type="submit" role="button" class="btn btn-secondary">Enviar</button>
                      <span id="form_result" class="d-block text-center"/>
                    </div>
                  </div>

                </form>
              </div>
            </section>
          </div>
        </section>
      </div>
    </section>
  </template>
</odoo>
