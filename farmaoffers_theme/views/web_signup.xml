<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="farmaoffers_theme_signup" inherit_id="auth_signup.signup" name="Custom Sign Up">
      <xpath expr="//form[.//input[@name='csrf_token'] and .//input[@name='token'] and .//input[@name='redirect']]" position="replace">
        <div class="container-fo mx-auto my-0">
          <div class="basic-bg basic-bg-signup row">
            <div class="login-message col-12 col-md-6 d-flex justify-content-center align-items-center">
              <div class="text-white text-left font-montserrat font-weight-bold">
                LAS MEJORES OFERTAS LAS TRAEMOS PARA USTED
                <span class="text-green2">CADA DÍA</span>
              </div>
            </div>

            <div class="col-12 col-md-6 d-flex justify-content-center align-items-center">
              <form class="login-form-custom" role="form" method="post" t-if="not message">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="login-img">
                  <h2>
                    <span t-field="res_company.logo"
                          t-options="{'widget': 'image'}"
                          t-att-alt="'Logo of %s' % res_company.name"
                          t-att-title="res_company.name"/>
                  </h2>
                </div>

                <div class="login-heading text-center">
                  <h2 class="text-dark-fo">Nuevo usuario</h2>
                  <h3>Cree su cuenta llenando el formulario</h3>
                </div>

                <t t-if="error and len(error) &gt; 0">
                  <div t-foreach="error" t-as="err"
                       class="form-group col-12 alert alert-danger font-montserrat font-8-5 mb-1" role="alert">
                    <i class="fa fa-exclamation" aria-hidden="false"></i>
                    <t t-esc="err['error']"/>
                  </div>
                </t>

                <t t-call="auth_signup.fields">
                  <t t-set="only_passwords" t-value="bool(token and not invalid_token)"/>
                </t>

                <input type="hidden" name="redirect" t-att-value="redirect"/>
                <input type="hidden" name="token" t-att-value="token"/>

                <div class="text-center oe_login_buttons pt-3">
                  <button type="submit" class="btn btn-secondary">Registrarse</button>

                  <div class="helper-links justify-content-center mt-3">
                    <a t-attf-href="/web/login?{{ keep_query() }}">¿Ya tienes una cuenta?</a>
                  </div>

                  <div class="o_login_auth"/>
                </div>
              </form>
            </div>
          </div>
        </div>
      </xpath>
    </template>
  </data>
</odoo>
