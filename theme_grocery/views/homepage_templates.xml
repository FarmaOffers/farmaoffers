<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="homepage_products_item" model="ir.ui.view">
        <field name="name">Grocery Product Item</field>
        <field name="type">qweb</field>
        <field name="key">theme_grocery.homepage_products_item</field>
        <field name="arch" type="xml">
            <t t-name="homepage_products_item">
                <t t-set="combination_info" t-value="product._get_combination_info()" />
                <form action="/shop/cart/update" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
                    <div itemscope="itemscope" itemtype="http://schema.org/Product" class="product_cards card border-0 shadow-sm h-100 my-3">
                        <!-- Product Image -->
                        <div class="oe_product_image">
                            <a itemprop="url" t-att-href="'/shop/product/%s' % slug(product)">
                                <img class="card-img-top img-fluid" itemprop="image" t-att-src="'/web/image/product.template/%s/image_512' % product.id" t-att-alt="product.name" />
                            </a>
                        </div>
                        <!-- Hover Buttons (now placed below image, above title) -->
                        <div class="hover-button d-flex justify-content-center gap-2 my-2">
                            <input name="product_id" t-att-value="product.product_variant_id.id" type="hidden" />
                            <t t-if="len(product.product_variant_ids) == 1">
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="fa fa-shopping-cart"></i>
                                </button>
                            </t>
                            <t t-if="len(product.product_variant_ids) &gt; 1">
                                <a class="btn btn-sm btn-primary" t-att-href="'/shop/product/%s' % slug(product)">
                                    <i class="fa fa-shopping-cart"></i>
                                </a>
                            </t>
                            <a t-att-href="'/shop/product/%s' % slug(product)" class="btn btn-sm btn-outline-secondary" title="View">
                                <i class="fa fa-eye"></i>
                            </a>
                        </div>
                        <!-- Product Details -->
                        <div class="card-body text-center">
                            <h6 class="card-title mb-2">
                                <a itemprop="name" t-att-href="'/shop/product/%s' % slug(product)" class="text-decoration-none text-dark product-name-truncate" t-field="product.name" />
                            </h6>
                            <div class="product_price">
                                <span class="fw-bold">
                                    <del t-attf-class="text-muted me-2 {{'' if combination_info['has_discounted_price'] else 'd-none'}}" t-esc="combination_info['list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                                    <span t-if="combination_info['price']" class="text-success" t-esc="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                                    <span itemprop="price" class="d-none" t-esc="combination_info['price']" />
                                    <span itemprop="priceCurrency" class="d-none" t-esc="website.currency_id.name" />
                                </span>
                            </div>
                        </div>
                    </div>
                </form>
            </t>
        </field>
    </record>
    <record id="grocery_homepage_view" model="ir.ui.view">
        <field name="name">Grocery Home</field>
        <field name="type">qweb</field>
        <field name="key">website.grocery_homepage</field>
        <field name="arch" type="xml">
            <t name="Home" t-name="website.grocery_homepage">
                <t t-call="website.layout">
                    <t t-set="pageName" t-value="'homepage'" />
                    <div id="wrap" class="oe_structure">
                        <t t-set="direction" t-value="request.env['res.lang'].search([('code', '=', lang)]).direction" />
                        <section class="pt16">
                            <div class="container">
                                <div class="row oe_structure">
                                    <div class="col-md-3">
                                        <div class="sidebar-nav">
                                            <div class="navbar navbar-default" role="navigation">
                                                <div class="navbar-header">
                                                    <button class="navbar-toggler w-100" type="button" data-bs-toggle="collapse" data-bs-target="#o_portal_navbar_content" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                                                        <i class="fa fa-bars d-inline-flex float-start"></i> Categories
                                                        <span class="fa fa-angle-down float-end"></span>
                                                    </button>
                                                </div>
                                                <div id="o_portal_navbar_content" class="navbar-collapse sidebar-navbar-collapse collapse show" style="overflow: auto; height: 340px;">
                                                    <ul class="nav navbar-nav">
                                                        <t t-foreach="website.get_homepage_categories()" t-as="category">
                                                            <li>
                                                                <a t-att-href="'/shop/category/' + slug(category)">
                                                                    <t t-esc="category.name" />
                                                                </a>
                                                            </li>
                                                        </t>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-9">
                                        <div id="homepageCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000" data-bs-wrap="true">
                                            <div class="carousel-inner">
                                                <t t-foreach="enumerate(sliders)" t-as="s">
                                                    <t t-set="index" t-value="s[0]" />
                                                    <t t-set="slide" t-value="s[1]" />
                                                    <div t-attf-class="carousel-item #{'active' if index == 0 else ''}">
                                                        <a t-att-href="slide.link or '#'" t-att-title="slide.name">
                                                            <img class="d-block w-100 img-fluid" t-att-src="'/website/image/homepage.slider/%s/image' % slide.id" t-att-alt="slide.name" />
                                                        </a>
                                                    </div>
                                                </t>
                                                <t t-if="not sliders">
                                                    <div class="carousel-item active">
                                                        <img class="d-block w-100 img-fluid" src="/theme_grocery/static/src/img/default.jpg" alt="Default Slide" />
                                                    </div>
                                                </t>
                                            </div>
                                            <div class="carousel-indicators homecarousel-indicators" >
                                                <t t-if="sliders">
                                                <t t-foreach="enumerate(sliders)" t-as="s">
                                                    <t t-set="index" t-value="s[0]" />
                                                    <button type="button" t-att-data-bs-target="'#homepageCarousel'" t-att-data-bs-slide-to="index" t-att-class="'active' if index == 0 else ''" t-att-aria-current="'true' if index == 0 else 'false'" t-att-aria-label="'Slide %s' % (index+1)">
                                                    </button>
                                                </t>
                                            </t>
                                            </div>
                                            <button class="carousel-control-prev" type="button" data-bs-target="#homepageCarousel" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Previous</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target="#homepageCarousel" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Next</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <div class="oe_structure" />
                        <section class="mt16 mb32">
                            <div class="container">
                                <div class="row oe_structure">
                                    <t t-foreach="website.get_homepage_horizontal_banner()" t-as="banner">
                                        <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                                            <div class="horizontal-banner card border-0 h-100">
                                                <div class="bg-image">
                                                    <img t-attf-src="/website/image/homepage.horizontal.banner/{{banner.id}}/image" t-att-alt="banner.name" class="img-fluid rounded-top" t-if="direction == 'ltr'" />
                                                    <img t-attf-src="/website/image/homepage.horizontal.banner/{{banner.id}}/rtl_image" t-att-alt="banner.name" class="img-fluid rounded-top" t-if="direction == 'rtl'" />
                                                </div>
                                                <div class="content">
                                                    <div class="content-inner">
                                                        <div class="banner">
                                                            <div class="banner-content">
                                                                <h3>
                                                                    <t t-esc="banner.name" />
                                                                </h3>
                                                                <p>
                                                                    <t t-esc="banner.sub_heading" />
                                                                </p>
                                                            </div>
                                                            <div class="banner-button">
                                                                <a class="btn btn-banner-light" t-att-href="banner.link" title="Shop now"><span>Shop now</span></a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </section>
                        <section class="oe_website_sale">
                            <div class="container">
                                <div class="row oe_structure">
                                    <div class="col-lg-3 col-md-3 hidden-sm hidden-xs">
                                        <div class="oe_structure">
                                            <section class="s_big_picture mb32">
                                                <div class="container">
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <t t-foreach="website.get_homepage_vertical_banner()" t-as="banner">
                                                                <a t-att-href="banner.link">
                                                                    <img class="img img-responsive w-100" t-attf-src="/website/image/homepage.vertical.banner/{{banner.id}}/image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'ltr'" />
                                                                    <img class="img img-responsive w-100" t-attf-src="/website/image/homepage.vertical.banner/{{banner.id}}/rtl_image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'rtl'" />
                                                                </a>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </div>
                                            </section>
                                            <div class="clearfix" />
                                            <div class="oe_structure" />
                                            <section class="list-slider best-seller mb32">
                                                <div class="block-title"><span>Best Sellers</span></div>
                                                <t t-set="products" t-value="website.get_bestseller_products()" />
                                                <div id="bestSellerCarousel" class="carousel slide" data-bs-ride="carousel">
                                                    <div class="carousel-inner">
                                                        <t t-foreach="range(0, len(products), 5)" t-as="step">
                                                            <div t-att-class="'carousel-item%s' % (' active' if step == 0 else '')">
                                                                <div class="list-group ">
                                                                    <t t-foreach="products[step:step+5]" t-as="product">
                                                                        <div class="list-group-item d-flex align-items-center border-0">
                                                                            <img class="img-thumbnail me-3" style="width: 60px; height: 60px; object-fit: contain;" t-att-src="'/web/image/product.template/%s/image_512' % product.id" t-att-title="product.name" />
                                                                            <div class="flex-fill">
                                                                                <a t-att-href="'/shop/product/%s' % slug(product)" class="fw-bold d-block">
                                                                                    <t t-esc="product.name" />
                                                                                </a>
                                                                                <t t-set="combination_info" t-value="product._get_combination_info()" />
                                                                                <div class="price product_price text-success fw-bold">
                                                                                    <span t-if="combination_info['price']" t-esc="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}" />
                                                                                </div>
                                                                                <t t-if="len(product.product_variant_ids) == 1">
                                                                                    <form action="/shop/cart/update" class="js_add_cart_variants" method="POST">
                                                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
                                                                                        <input name="product_id" t-att-value="product.product_variant_id.id" type="hidden" />
                                                                                        <a class="add-cart-btn a-submit text-primary">Add to Cart</a>
                                                                                    </form>
                                                                                </t>
                                                                                <t t-if="len(product.product_variant_ids) &gt; 1">
                                                                                    <a class="add-cart-btn text-primary" t-att-href="'/shop/product/%s' % slug(product)">Add to Cart</a>
                                                                                </t>
                                                                            </div>
                                                                        </div>
                                                                    </t>
                                                                </div>
                                                            </div>
                                                        </t>
                                                    </div>
                                                    <button class="carousel-control-prev" type="button" data-bs-target="#bestSellerCarousel" data-bs-slide="prev">
                                                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                        <span class="visually-hidden">Previous</span>
                                                    </button>
                                                    <button class="carousel-control-next" type="button" data-bs-target="#bestSellerCarousel" data-bs-slide="next">
                                                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                        <span class="visually-hidden">Next</span>
                                                    </button>
                                                </div>
                                            </section>
                                            <section class="list-slider review-slider mb32">
                                                <div class="block-title"><span>Testimonials</span></div>
                                                <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
                                                    <div class="carousel-inner">
                                                        <t t-foreach="range(0, len(testimonials), 1)" t-as="testimonial">
                                                            <div t-att-class="'carousel-item%s' % (' active' if testimonial == 0 else '')">
                                                                <t t-foreach="testimonials[testimonial:testimonial+1]" t-as="testimonial">
                                                                    <div class="text-center">
                                                                        <div class="reviewer-image mb-2">
                                                                            <img class="rounded-circle" t-att-src="testimonial.image and '/web/image/customer.testimonial/%s/image' % testimonial.id or '/web/static/src/img/placeholder.png'" t-att-alt="testimonial.name or 'Testimonial'" />
                                                                        </div>
                                                                        <div class="reviewer-info">
                                                                            <div class="reviewer-name fw-bold">
                                                                                <t t-esc="testimonial.name" />
                                                                            </div>
                                                                            <div class="review">
                                                                                <t t-esc="testimonial.review" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </t>
                                                            </div>
                                                        </t>
                                                    </div>
                                                    <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                                                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                        <span class="visually-hidden">Previous</span>
                                                    </button>
                                                    <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                                                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                        <span class="visually-hidden">Next</span>
                                                    </button>
                                                </div>
                                            </section>
                                            <div class="clearfix" />
                                            <div class="oe_structure" />
                                        </div>
                                    </div>
                                    <div class="col-lg-9 col-md-9 col-sm-12 col-12">
                                        <!-- Top Categories -->
                                        <div class="homepage-expore d-flex justify-content-between align-items-center">
                                            <span class="left">Top Categories Pick-up your order in store at Same - Day, Hurry!</span>
                                            <button href="/shop" class="text-decoration-none btn btn-primary p-3">Explore All</button>
                                        </div>
                                        <!-- Trending Products -->
                                        <div class="trending-product">
                                            <div class="title mb-3">Trending Products</div>
                                            <!-- Tabs -->
                                            <ul class="nav nav-tabs justify-content-end" id="trendingTabs" role="tablist">
                                                <li class="nav-item" role="presentation">
                                                    <button class="nav-link active" id="bestseller-tab" data-bs-toggle="tab" data-bs-target="#bestseller" type="button" role="tab" aria-controls="bestseller" aria-selected="true">
                                                        Bestseller
                                                    </button>
                                                </li>
                                                <li class="nav-item" role="presentation">
                                                    <button class="nav-link" id="latest-tab" data-bs-toggle="tab" data-bs-target="#latest" type="button" role="tab" aria-controls="latest" aria-selected="false">
                                                        Latest
                                                    </button>
                                                </li>
                                                <li class="nav-item" role="presentation">
                                                    <button class="nav-link" id="featured-tab" data-bs-toggle="tab" data-bs-target="#featured" type="button" role="tab" aria-controls="featured" aria-selected="false">
                                                        Featured
                                                    </button>
                                                </li>
                                            </ul>
                                            <!-- Tab Content -->
                                            <div class="tab-content mt-3">
                                                <!-- Bestseller -->
                                                <div class="tab-pane fade show active" id="bestseller" role="tabpanel" aria-labelledby="bestseller-tab">
                                                    <div id="bestsellerCarousel" class="carousel slide" data-bs-ride="carousel">
                                                        <div class="carousel-inner">
                                                            <t t-set="products" t-value="website.get_bestseller_products()" />
                                                            <t t-foreach="range(0, len(products), 4)" t-as="step">
                                                                <div class="carousel-item" t-att-class="step == 0 and 'active' or ''">
                                                                    <div class="row g-3">
                                                                        <t t-foreach="products[step:step+4]" t-as="product">
                                                                            <div class="col-6 col-md-3 col-sm-6 oe_product_18">
                                                                                <t t-call="theme_grocery.homepage_products_item" />
                                                                            </div>
                                                                        </t>
                                                                    </div>
                                                                </div>
                                                            </t>
                                                        </div>
                                                        <button class="carousel-control-prev" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="prev">
                                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Previous</span>
                                                        </button>
                                                        <button class="carousel-control-next" type="button" data-bs-target="#bestsellerCarousel" data-bs-slide="next">
                                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Next</span>
                                                        </button>
                                                    </div>
                                                </div>
                                                <!-- Latest -->
                                                <div class="tab-pane fade" id="latest" role="tabpanel" aria-labelledby="latest-tab">
                                                    <div id="latestCarousel" class="carousel slide" data-bs-ride="carousel">
                                                        <div class="carousel-inner">
                                                            <t t-set="products" t-value="website.get_latest_products()" />
                                                            <t t-foreach="range(0, len(products), 4)" t-as="step">
                                                                <div class="carousel-item" t-att-class="step == 0 and 'active' or ''">
                                                                    <div class="row g-3">
                                                                        <t t-foreach="products[step:step+4]" t-as="product">
                                                                            <div class="col-md-3 col-sm-6 oe_product_18">
                                                                                <t t-call="theme_grocery.homepage_products_item" />
                                                                            </div>
                                                                        </t>
                                                                    </div>
                                                                </div>
                                                            </t>
                                                        </div>
                                                        <button class="carousel-control-prev" type="button" data-bs-target="#latestCarousel" data-bs-slide="prev">
                                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Previous</span>
                                                        </button>
                                                        <button class="carousel-control-next" type="button" data-bs-target="#latestCarousel" data-bs-slide="next">
                                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Next</span>
                                                        </button>
                                                    </div>
                                                </div>
                                                <!-- Featured -->
                                                <div class="tab-pane fade" id="featured" role="tabpanel" aria-labelledby="featured-tab">
                                                    <div id="featuredCarousel" class="carousel slide" data-bs-ride="carousel">
                                                        <div class="carousel-inner">
                                                            <t t-set="products" t-value="website.get_featured_products()" />
                                                            <t t-foreach="range(0, len(products), 4)" t-as="step">
                                                                <div class="carousel-item" t-att-class="step == 0 and 'active' or ''">
                                                                    <div class="row g-3">
                                                                        <t t-foreach="products[step:step+4]" t-as="product">
                                                                            <div class="col-md-3 col-sm-6 oe_product_18">
                                                                                <t t-call="theme_grocery.homepage_products_item" />
                                                                            </div>
                                                                        </t>
                                                                    </div>
                                                                </div>
                                                            </t>
                                                        </div>
                                                        <button class="carousel-control-prev" type="button" data-bs-target="#featuredCarousel" data-bs-slide="prev">
                                                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Previous</span>
                                                        </button>
                                                        <button class="carousel-control-next" type="button" data-bs-target="#featuredCarousel" data-bs-slide="next">
                                                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                            <span class="visually-hidden">Next</span>
                                                        </button>
                                                        <!-- Full Banner -->
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="mt-3"></div>
                                        </div>
                                        <div class="clearfix" />
                                        <div class="oe_structure" />
                                        <section class="s_big_picture mb-4">
                                            <div class="row oe_structure">
                                                <div class="col-12 homepage_banner_2">
                                                    <t t-foreach="website.get_homepage_horizontal_full_banner()" t-as="banner">
                                                        <a t-att-href="banner.link">
                                                            <img class="img-fluid w-100" t-attf-src="/website/image/homepage.horizontal.full.banner/{{banner.id}}/image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'ltr'" />
                                                            <img class="img-fluid w-100" t-attf-src="/website/image/homepage.horizontal.full.banner/{{banner.id}}/rtl_image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'rtl'" />
                                                        </a>
                                                    </t>
                                                </div>
                                            </div>
                                        </section>
                                        <section class="s_text_image homepage_banner_2 mb-3">
                                            <div class="row oe_structure">
                                                <t t-foreach="website.get_homepage_horizontal_half_banner()" t-as="banner">
                                                    <div class="col-md-6 mb-3">
                                                        <a t-att-href="banner.link">
                                                            <img class="img-fluid w-100" t-attf-src="/website/image/homepage.horizontal.half.banner/{{banner.id}}/image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'ltr'" />
                                                            <img class="img-fluid w-100" t-attf-src="/website/image/homepage.horizontal.half.banner/{{banner.id}}/rtl_image" t-att-alt="banner.name" t-att-title="banner.name" t-if="direction == 'rtl'" />
                                                        </a>
                                                    </div>
                                                </t>
                                            </div>
                                        </section>
                                        <div id="latestBlogCarousel" class="carousel slide homepage-blogs mb-4" data-bs-ride="carousel">
                                            <!-- Title -->
                                            <div class="title mb-3">Latest Blog</div>
                                            <!-- Carousel inner -->
                                            <div class="carousel-inner">
                                                <t t-set="posts" t-value="website.get_latest_blog_posts()" />
                                                <t t-foreach="range(0, len(posts), 3)" t-as="idx">
                                                    <div t-att-class="'carousel-item' + (' active' if idx == 0 else '')">
                                                        <div class="row g-3 align-items-stretch">
                                                            <t t-foreach="posts[idx:idx+3]" t-as="blog_post">
                                                                <div class="col-12 col-md-4 d-flex">
                                                                    <div class="card border-0 shadow-sm w-100 d-flex flex-column">
                                                                        <!-- Fixed height image -->
                                                                        <a t-attf-href="/blog/#{ slug(blog_post.blog_id) }/post/#{ slug(blog_post) }" class="d-block" style="height:200px; overflow:hidden;">
                                                                            <t t-set="img_path" t-value="website.get_cover_image(blog_post)" />
                                                                            <img t-att-src="img_path and len(img_path)>2 and img_path[1:-1]" t-att-title="blog_post.name" t-att-alt="blog_post.name" class="card-img-top img-fluid h-100 w-100 object-fit-cover" />
                                                                        </a>
                                                                        <div class="card-body d-flex flex-column">
                                                                            <a class="latest-posts-title text-decoration-none fw-bold mb-2" t-attf-href="/blog/#{ slug(blog_post.blog_id) }/post/#{ slug(blog_post) }">
                                                                                <t t-esc="blog_post.name" />
                                                                            </a>
                                                                            <p class="text-muted small mb-2 flex-grow-1">
                                                                                <t t-esc="blog_post.teaser" />
                                                                            </p>
                                                                            <a t-attf-href="/blog/#{ slug(blog_post.blog_id) }/post/#{ slug(blog_post) }" class="link text-primary fw-bold mt-auto">
                                                                                Read more →
                                                                            </a>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>
                                            <!-- Controls -->
                                            <button class="carousel-control-prev" type="button" data-bs-target="#latestBlogCarousel" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Previous</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target="#latestBlogCarousel" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Next</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                </t>
            </t>
        </field>
    </record>
    <record id="grocery_homepage" model="website.page">
        <field name="url">/grocery_homepage</field>
        <field name="is_homepage" eval="True"></field>
        <field name="website_published">True</field>
        <field name="view_id" ref="grocery_homepage_view" />
    </record>
    <record id="website.default_website" model="website">
        <field name="homepage_url">/grocery_homepage</field>
    </record>
</odoo>