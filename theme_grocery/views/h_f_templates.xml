        <xpath expr="//a[hasclass('btn-secondary')]" position="replace">
            <a role="button" href="#" class="dropdown-toggle" data-toggle="dropdown">
                <i class="fa fa-money" aria-hidden="false"></i> <span class="label_text">
                    <t t-esc="curr_pl and curr_pl.name or ' - '" /></span>
            </a>
        </xpath>
    </template> -->
</odoo>