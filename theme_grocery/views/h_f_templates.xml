<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="website_glossary_header_style_1" inherit_id="website.layout" name="Header Style - 1" active="False">
        <xpath expr="//header" position="replace">
            <div class="header-top">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-5 col-md-5 col-sm-5 col-5 language-currency-top">
                            <div class="language-wrapper">
                                <div class="dropdown" t-if="request.is_frontend_multilang and len(frontend_languages) &gt; 1">
                                    <div class="dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa fa-globe"></i> <span class="label_text">Language</span>
                                        <span class="caret"></span>
                                    </div>
                                    <ul class="dropdown-menu">
                                        <t t-foreach="language_ids" t-as="lg">
                                            <li class="list-inline-item">
                                                <a t-att-href="url_for(request.httprequest.path + '?' + keep_query(), lang_code=lg[0])" class="dropdown-item js_change_lang" t-att-data-url_code="lg[1]">
                                                    <t t-esc="lg[2].split('/').pop()" />
                                                </a>
                                            </li>
                                        </t>
                                        <li groups="website.group_website_publisher" class="list-inline-item">
                                            <t t-set="url_return" t-value="quote_plus(url_for('', '[lang]') + '?' + keep_query())" />
                                            <a class="dropdown-item d-sm-block" t-attf-href="/web#action=base.action_view_base_language_install&amp;website_id=#{website.id if website else ''}&amp;url_return=#{url_return}">
                                                <i class="fa fa-plus-circle"></i> Add a language...
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="currency-wrapper">
                                <t t-call="website_sale.pricelist_list" />
                            </div>
                        </div>
                        <div class="col-lg-7 col-md-7 col-md-7 col-7 header-links-top">
                            <div class="toplinks">
                                <ul class="header links">
                                    <li class="authorization-link" data-label="or" t-if="user_id._is_public()"><a href="/web/login">Login</a></li>
                                    <li t-if="user_id._is_public()"><a href="/web/signup">Register</a></li>
                                    <li class="dropdown" t-if="not user_id._is_public()">
                                        <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown">
                                            <b>
                                                <span t-esc="user_id.name[:23] + '...' if user_id.name and len(user_id.name) > 25 else user_id.name" />
                                                <span class="caret"></span>
                                            </b>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a t-attf-href="/web/session/logout?redirect=/" class="dropdown-item">
                                                    <i class="fa fa-sign-out me-1"></i> Logout
                                                </a>
                                            </li>
                                        </ul>
                                    </li>
                                </ul>
                            </div>
                            <div class="track-order">
                                <a href="#">Track You Order</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-middle">
                <div class="container">
                    <div class="d-flex align-items-center justify-content-between custom_row flex-wrap">
                        <!-- Logo -->
                        <div class="logo-header me-2"> <a class="d-inline-block" href="/" title="Logo" style="max-width: 80px;"> <span t-field="res_company.logo" t-options="{'widget': 'image'}" class="img-fluid" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name" /> </a> </div> <!-- Search -->
                        <div class="flex-grow-1 search-header mx-2">
                            <form method="get" action="/shop" class="d-flex o_website_sale_search">
                                <!-- Category (desktop only) -->
                                <div class="d-none d-md-block me-2" style="min-width:150px;"> <select class="form-select" name="category">
                                        <option value="" t-att-selected="not search">All Products</option>
                                        <t t-foreach="website.get_categories()" t-as="category_item">
                                            <option t-att-value="category_item.id" t-att-selected="search and category and category.id == category_item.id">
                                                <t t-esc="category_item.name" />
                                            </option>
                                        </t>
                                    </select> </div> <!-- Search Input --> <input type="text" name="search" class="form-control me-2" placeholder="Enter keywords to search..." t-att-value="search" /> <button type="submit" class="btn btn-primary"> <i class="fa fa-search"></i> </button>
                            </form>
                        </div> <!-- Cart -->
                        <div class="cart-header ms-2">
                            <t t-set="website_sale_order" t-value="website.sale_get_order()" /> <a class="btn btn-outline-primary position-relative d-flex align-items-center" href="/shop/cart"> <i class="fa fa-shopping-cart me-1"></i> <span class="d-none d-md-inline">My Cart</span> <span class="counter-number badge bg-danger ms-1" id="my_cart">
                                    <t t-esc="website_sale_order and website_sale_order.cart_quantity or '0'" /> </span> <span class="price-minicart d-none d-md-inline-block ms-1">
                                    <t t-if="website_sale_order.amount_total > 0"> <span t-field="website_sale_order.amount_total" t-options='{"widget": "monetary", "display_currency": website_sale_order.pricelist_id.currency_id}' /> </t>
                                    <t t-else="">
                                        <t t-esc="website.currency_id.symbol" /> 0.00 </t>
                                </span> </a> </div>
                    </div>
                </div>
            </div>
            <header>
                <nav class="navbar navbar-expand-md navbar-light">
                    <div class="container text-center">
                        <div class="collapse navbar-collapse CustomScrollbar main_menu" id="top_menu_collapse">
                            <ul class="nav navbar-nav ml-auto mx-auto text-right" id="top_menu">
                                <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                    <t t-call="website.submenu">
                                        <t t-set="item_class" t-value="'nav-item'" />
                                        <t t-set="link_class" t-value="'nav-link'" />
                                    </t>
                                </t>
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
        </xpath>
    </template>
    <template id="template_footer_style_1" inherit_id="website.layout" name="Footer Style - 1" active="False">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="container hidden-print" t-if='not no_footer'>
                <div class="row">
                    <div class="col-md-3">
                        <div class="logo-footer">
                            <h2><span t-field="res_company.logo" t-options="{'widget': 'image'}" t-att-alt="'Logo of %s' % res_company.name" t-att-title="res_company.name" /></h2>
                        </div>
                        <div class="about-us">
                            <ul>
                                <li class="address">
                                    <t t-if="res_company.street"><span t-field="res_company.street" />, </t>
                                    <t t-if="res_company.street2"><span t-field="res_company.street2" />, </t>
                                    <t t-if="res_company.city"><span t-field="res_company.city" />, </t>
                                    <t t-if="res_company.zip"><span t-field="res_company.zip" />, </t>
                                    <t t-if="res_company.country_id"><span t-field="res_company.country_id.name" /></t>
                                </li>
                                <li class="phone" t-if="res_company.phone"><span t-field="res_company.phone" /></li>
                                <li class="email" t-if="res_company.email"><span t-field="res_company.email" /></li>
                                <li class="time-open">Open time: 8:00AM - 16:PM</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="block-footer">
                            <div class="title-block-footer">Information</div>
                            <div class="content-block-footer">
                                <ul>
                                    <li><a href="#" title="About Us">About Us</a></li>
                                    <li><a href="#" title="Delivery Information">Delivery Information</a></li>
                                    <li><a href="#" title="Wishlist">Privacy Policy</a></li>
                                    <li><a href="#" title="Customer Service">Terms &amp; Conditions</a></li>
                                </ul>
                            </div>
                            <div id="info" class="hidden">
                                <ul></ul>
                            </div>
                            <div class="title-block-footer newsletter-top">Newsletter</div>
                            <div class="s_newsletter_subscribe_form s_newsletter_list js_subscribe" data-vxml="001" data-list-id="0" data-name="Newsletter Form">
                                <div class="js_subscribed_wrap d-none">
                                    <p class="h4-fs text-center text-success"><i class="fa fa-check-circle-o" role="img" /> Thanks for registering!</p>
                                </div>
                                <div class="js_subscribe_wrap">
                                    <div class="input-group">
                                        <input type="email" name="email" class="js_subscribe_value form-control" placeholder="johnsmith@example.com" />
                                        <a role="button" href="#" class="btn btn-primary js_subscribe_btn o_submit">Subscribe</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="block-footer">
                            <div class="title-block-footer">My Account</div>
                            <div class="content-block-footer">
                                <ul>
                                    <li><a href="/my" title="Dashboard">Dashboard</a></li>
                                    <li><a href="/shop/wishlist" title="Wishlist">Wishlist</a></li>
                                    <li><a href="/contactus" title="Customer Service">Customer Service</a></li>
                                    <li><a href="#" title="Returns / Exchange">Returns</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="block-footer">
                            <div class="title-block-footer">Extra</div>
                            <div class="content-block-footer">
                                <ul>
                                    <li><a href="#" title="Brands">Brands</a></li>
                                    <li><a href="#" title="Gift Certificate">Gift Certificate</a></li>
                                    <li><a href="#" title="Affiliate">Affiliate</a></li>
                                    <li><a href="#" title="Support">Support</a></li>
                                    <li><a href="#" title="Sitemap">Sitemap</a></li>
                                </ul>
                            </div>
                            <ul class="app-list">
                                <li>
                                    <a href="#" title="Appstore">
                                        <img src="/theme_grocery/static/src/img/appstore.jpg" alt="Appstore" />
                                    </a>
                                </li>
                                <li>
                                    <a href="#" title="Google Play">
                                        <img src="/theme_grocery/static/src/img/playstore.jpg" alt="Google Play" />
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer_copyright">
                <div class="container">
                    <div class="pull-left">
                        <span>Copyright &amp;copy; 2019
                            <t t-esc="res_company.name" />. All Rights Reserved.</span>
                    </div>
                    <div class="pull-right">
                        <a href="https://www.kanakinfosystems.com" target="_blank">Designed by Kanak Infosystems LLP.</a>
                    </div>
                    <div class="clearfix"></div>
                </div>
            </div>
        </xpath>
    </template>
    <template id="wishlist_link" inherit_id="theme_grocery.website_glossary_header_style_1" name="Header Shop Wishlist Link">
        <xpath expr="//div[hasclass('track-order')]" position="before">
            <t t-set='wishcount' t-value="len(request.env['product.wishlist'].current())" />
            <div id="my_wish" class="o_wsale_my_wish">
                <a href="/shop/wishlist">
                    <i class="fa fa-heart"></i>
                    <span class="d-none d-sm-inline">Wishlist</span> <sup t-attf-class="my_wish_quantity o_animate_blink label label-primary">
                        <t t-esc='wishcount' /></sup>
                </a>
            </div>
        </xpath>
    </template>
