<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="aspl_provider_form_cybersource" model="ir.ui.view">
    <field name="name">payment.provider.form.inherit.cybersource</field>
    <field name="model">payment.provider</field>
    <!-- Asegúrate de que exista en tu core; si no, dime el XMLID correcto -->
    <field name="inherit_id" ref="payment.payment_provider_form"/>
    <field name="arch" type="xml">
      <!-- insertamos después del selector de provider -->
      <xpath expr="//field[@name='code']" position="after">
        <!-- JSON estricto con comillas dobles internas -->
        <group modifiers='{"invisible": [["code", "!=", "cybersource"]] }'>
          <field name="cybersource_merchant_id" groups="base.group_user"/>
          <field name="cybersource_key" groups="base.group_user" password="True"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>