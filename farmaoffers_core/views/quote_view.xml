<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List -->
    <record id="view_fo_quote_list" model="ir.ui.view">
        <field name="name">fo.quote.list</field>
        <field name="model">fo.quote</field>
        <field name="arch" type="xml">
            <list>
                <field name="submission_date"/>
                <field name="name"/>
                <field name="lastname"/>
                <field name="city"/>
                <field name="phone"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_fo_quote_form" model="ir.ui.view">
        <field name="name">fo.quote.form</field>
        <field name="model">fo.quote</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Customer Info">
                        <field name="submission_date" readonly="1"/>
                        <field name="name"/>
                        <field name="lastname"/>
                        <field name="city"/>
                        <field name="address"/>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>

                    <group string="Quote Request">
                        <field name="description"/>
                        <field name="file" widget="pdf_viewer"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fo_quotes" model="ir.actions.act_window">
        <field name="name">Quotes</field>
        <field name="res_model">fo.quote</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
